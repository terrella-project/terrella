{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["ai", "ollama", "host"],
  "title": "Ollama Host",
  "uid": "ollama-host",
  "version": 1,
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "type": "stat",
      "title": "Ollama up",
      "id": 1,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"refId": "A", "expr": "max(ollama_up)", "instant": true}],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "Down", "color": "red"}, "1": {"text": "Up", "color": "green"}}}
          ]
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "stat",
      "title": "Installed models",
      "id": 2,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"refId": "A", "expr": "max(ollama_installed_models)", "instant": true}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "stat",
      "title": "Loaded models now",
      "id": 3,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"refId": "A", "expr": "sum(ollama_model_loaded)", "instant": true}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "stat",
      "title": "Loaded VRAM now",
      "id": 4,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "targets": [{"refId": "A", "expr": "sum(ollama_model_vram_bytes)", "instant": true}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "timeseries",
      "title": "Loaded model count",
      "id": 5,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"refId": "A", "expr": "sum(ollama_model_loaded)"}]
    },
    {
      "type": "timeseries",
      "title": "VRAM by loaded model",
      "id": 6,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "targets": [{"refId": "A", "expr": "sum by (model) (ollama_model_vram_bytes)"}]
    },
    {
      "type": "timeseries",
      "title": "Loaded state by model",
      "id": 7,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{"refId": "A", "expr": "ollama_model_loaded"}]
    },
    {
      "type": "barchart",
      "title": "Installed model sizes",
      "id": 8,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "expr": "sort_desc(ollama_model_installed_bytes)",
          "instant": true,
          "legendFormat": "{{model}}"
        }
      ]
    }
  ]
}
