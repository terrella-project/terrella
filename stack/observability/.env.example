# Copy to .env and fill in. .env is gitignored.
# Or run scripts/generate-env.sh which generates strong random secrets and writes this file.

# Postgres
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-use-generate-env-sh
POSTGRES_DB=litellm

# LiteLLM
# master_key is for admin/UI only — do NOT share this. Tools should use virtual keys.
LITELLM_MASTER_KEY=sk-master-change-me
LITELLM_SALT_KEY=change-me-32-bytes-base64

# Grafana
GRAFANA_ADMIN_PASSWORD=change-me

# Backend provider keys (NOT stored here — sourced from ~/.config/trackpro/secrets via shell env).
# docker-compose.yml interpolates these at `up` time, so they must be exported in the calling shell.
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
