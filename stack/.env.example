# Copy to .env and fill in. .env is gitignored.
# Or run scripts/generate-env.sh which generates strong random secrets and writes this file.

# Postgres
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-use-generate-env-sh
POSTGRES_DB=litellm

# Open WebUI — dedicated Postgres database for chats/settings/users
# (interpolated into Open WebUI's DATABASE_URL). Must exist before Open WebUI
# starts: createdb -U litellm openwebui
OPENWEBUI_DB=openwebui

# LiteLLM
# master_key is for admin/UI only — do NOT share this. Tools should use virtual keys.
LITELLM_MASTER_KEY=sk-master-change-me
LITELLM_SALT_KEY=change-me-32-bytes-base64
# Optional read-only LiteLLM key the litellm-exporter uses for route-count metrics.
LITELLM_EXPORTER_API_KEY=

# Grafana
GRAFANA_ADMIN_PASSWORD=change-me

# Backend provider API keys — fill these in after running generate-env.sh.
# Leave a key blank to disable that provider in LiteLLM.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# GitHub MCP — PAT needs 'repo' scope (read-only: Contents, Metadata).
GITHUB_PAT=ghp_your_token_here
