{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["ai", "spend"],
  "title": "AI Stack Overview",
  "uid": "ai-stack-overview",
  "version": 1,
  "time": {"from": "now-30d", "to": "now"},
  "panels": [
    {
      "type": "stat",
      "title": "Calls in window (LiteLLM)",
      "id": 1,
      "datasource": {"type": "postgres", "uid": "LiteLLM-Postgres"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "select count(*) as value from \"LiteLLM_SpendLogs\" where \"startTime\" between $__timeFrom() and $__timeTo();"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "stat",
      "title": "Per-call spend (LiteLLM)",
      "id": 2,
      "datasource": {"type": "postgres", "uid": "LiteLLM-Postgres"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "select coalesce(sum(spend), 0) as value from \"LiteLLM_SpendLogs\" where \"startTime\" between $__timeFrom() and $__timeTo();"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "stat",
      "title": "Subscriptions in window",
      "id": 3,
      "datasource": {"type": "postgres", "uid": "LiteLLM-Postgres"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "select coalesce(sum(amount_usd), 0) as value from monthly_costs where (month::date) between $__timeFrom()::date and $__timeTo()::date;"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "stat",
      "title": "Total spend (combined)",
      "id": 4,
      "datasource": {"type": "postgres", "uid": "LiteLLM-Postgres"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "with c as (select coalesce(sum(spend),0) as v from \"LiteLLM_SpendLogs\" where \"startTime\" between $__timeFrom() and $__timeTo()), s as (select coalesce(sum(amount_usd),0) as v from monthly_costs where (month::date) between $__timeFrom()::date and $__timeTo()::date) select (c.v + s.v) as value from c, s;"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "barchart",
      "title": "Spend by source (combined)",
      "id": 5,
      "datasource": {"type": "postgres", "uid": "LiteLLM-Postgres"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 4},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "select source, sum(amount) as amount from (select coalesce(custom_llm_provider, model) as source, sum(spend) as amount from \"LiteLLM_SpendLogs\" where \"startTime\" between $__timeFrom() and $__timeTo() group by 1 union all select vendor as source, sum(amount_usd) as amount from monthly_costs where (month::date) between $__timeFrom()::date and $__timeTo()::date group by 1) t group by source order by amount desc;"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Daily spend (LiteLLM only)",
      "id": 6,
      "datasource": {"type": "postgres", "uid": "LiteLLM-Postgres"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "select date_trunc('day', \"startTime\") as time, coalesce(custom_llm_provider, model) as metric, sum(spend) as value from \"LiteLLM_SpendLogs\" where \"startTime\" between $__timeFrom() and $__timeTo() group by 1, 2 order by 1;"
        }
      ]
    },
    {
      "type": "table",
      "title": "Recent calls",
      "id": 7,
      "datasource": {"type": "postgres", "uid": "LiteLLM-Postgres"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 13},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "select \"startTime\" as time, \"api_key\" as key, model, custom_llm_provider as provider, total_tokens as tokens, spend, \"end_user\" as user from \"LiteLLM_SpendLogs\" where \"startTime\" between $__timeFrom() and $__timeTo() order by \"startTime\" desc limit 100;"
        }
      ]
    },
    {
      "type": "table",
      "title": "Subscription log",
      "id": 8,
      "datasource": {"type": "postgres", "uid": "LiteLLM-Postgres"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 22},
      "fieldConfig": {"defaults": {"custom": {"align": "auto"}}, "overrides": [{"matcher": {"id": "byName", "options": "amount_usd"}, "properties": [{"id": "unit", "value": "currencyUSD"}]}]},
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "select month, vendor, amount_usd, notes, created_at from monthly_costs order by month desc, vendor;"
        }
      ]
    }
  ]
}
